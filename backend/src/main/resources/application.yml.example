spring:
  application:
    name: cvcraft-backend

  datasource:
    url: jdbc:postgresql://localhost:5432/cvcraft
    username: postgres
    password: YOUR_DB_PASSWORD_HERE
    hikari:
      maximum-pool-size: 10
      minimum-idle: 2

  jpa:
    hibernate:
      ddl-auto: update
    show-sql: false
    properties:
      hibernate:
        dialect: org.hibernate.dialect.PostgreSQLDialect
        format_sql: true

  jackson:
    serialization:
      write-dates-as-timestamps: false
    default-property-inclusion: non_null

  servlet:
    multipart:
      max-file-size: 50MB
      max-request-size: 50MB

server:
  port: 8080
  error:
    include-message: never

app:
  jwt:
    secret: ${JWT_SECRET:YOUR_JWT_SECRET_MIN_256_BITS_HERE}
    expiration: ${JWT_EXPIRATION:86400000}         # 1 gün (ms)
    refresh-expiration: ${JWT_REFRESH_EXPIRATION:604800000}  # 7 gün (ms)

  stripe:
    secret-key: ${STRIPE_SECRET_KEY:YOUR_STRIPE_SECRET_KEY_HERE}
    webhook-secret: ${STRIPE_WEBHOOK_SECRET:YOUR_STRIPE_WEBHOOK_SECRET_HERE}
    price:
      monthly: ${STRIPE_PRICE_MONTHLY:YOUR_MONTHLY_PRICE_ID_HERE}
      one-time: ${STRIPE_PRICE_ONE_TIME:YOUR_ONE_TIME_PRICE_ID_HERE}

  gemini:
    api-key: ${GEMINI_API_KEY:YOUR_GEMINI_API_KEY_HERE}
    model: gemini-flash-latest

  frontend-url: ${FRONTEND_URL:http://localhost:5173}

  google:
    client-id: ${GOOGLE_CLIENT_ID:YOUR_GOOGLE_CLIENT_ID_HERE}

logging:
  level:
    com.cvcraft: DEBUG
    org.springframework.security: INFO
